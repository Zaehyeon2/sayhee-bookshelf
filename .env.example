# Turso DB
TURSO_URL=file:./local.db
TURSO_TOKEN=

# 인증 (bcrypt 해시는 별도 스크립트로 생성)
#
# ⚠️ bcrypt 해시 ($2b$10$... 형태)는 .env.local에 넣을 때 모든 `$`를
#    반드시 `\$`로 escape해야 합니다. Next.js의 dotenv-expand가
#    `$2b`, `$10`을 변수 참조로 해석하여 hash 일부를 잘라먹습니다.
#    예: ADMIN_PASSWORD_HASH=\$2b\$10\$abcdef...
ADMIN_PASSWORD_HASH=
AUTH_SECRET=
