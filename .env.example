# Turso DB
TURSO_URL=file:./local.db
TURSO_TOKEN=

# 세션 JWT 서명 키 (32자 이상 필수)
AUTH_SECRET=

# 초기 admin 시드 (`pnpm run seed:admin` 한 번 실행)
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# 기존 책 데이터 마이그레이션 (`pnpm run migrate:existing-books` 한 번 실행)
# bcrypt 해시($2a$, $2b$, $2y$)를 직접 주입 — 평문이 아닙니다.
# ⚠️ .env.local에 넣을 때 모든 `$`를 `\$`로 escape (Next.js dotenv-expand 회피).
#    예: LEGACY_OWNER_PASSWORD_HASH=\$2a\$12\$abc...
LEGACY_OWNER_USERNAME=
LEGACY_OWNER_PASSWORD_HASH=

# 신규 멤버 / 비밀번호 reset 시 부여되는 초기 비밀번호 (8자 이상)
DEFAULT_USER_PASSWORD=

# 외부 작품 검색 API (선택)
# 책: 국립중앙도서관 SeoJi 정보 API — https://www.nl.go.kr/seoji 에서 발급
NL_KR_API_KEY=

# 영화: TMDB v3 API Read Access Token (v4) — https://www.themoviedb.org/settings/api
# Bearer 헤더로 전송. 짧은 v3 api_key가 아닌 긴 JWT 형태의 Read Access Token 사용.
TMDB_API_KEY=
